# ============================================================
# Ebook Empire — variaveis de ambiente de PRODUCAO (exemplo).
# Copie para o painel do provedor (Railway/Neon) — NUNCA commitar valores reais.
# ============================================================

# --- Banco (Neon Postgres) ---
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/ebook_empire?sslmode=require

# --- Auth ---
JWT_SECRET=troque-por-um-segredo-forte-aleatorio-min-32-chars

# --- Runtime ---
NODE_ENV=production
PUBLIC_BASE_URL=https://api.seu-dominio.com
USE_STUBS=false
STORAGE_DIR=/data/storage

# --- CORS (origem do frontend autorizada) ---
CORS_ORIGIN=https://app.seu-dominio.com

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Pagamento (Asaas) ---
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Mercado (Serper.dev) ---
SERPER_API_KEY=

# --- Meta (Instagram + Ads) ---
META_GRAPH_TOKEN=
META_AD_ACCOUNT_ID=

# --- WhatsApp (Evolution API) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- Marketplaces (Hotmart) ---
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=
HOTMART_WEBHOOK_TOKEN=

# --- Marketplaces (Kiwify) ---
KIWIFY_API_KEY=
KIWIFY_ACCOUNT_ID=
KIWIFY_WEBHOOK_SECRET=

# --- Afiliados / marketplace ---
MARKETPLACE_AFFILIATE_COMMISSION_PCT=50
AFFILIATE_OUTREACH_COOLDOWN_DAYS=7
AFFILIATE_COMMISSION_DEFAULT_PCT=30

# --- Upsell ---
UPSELL_DELAY_HOURS=24
UPSELL_MAX_FOLLOWUPS=3

# --- Metas operacionais ---
TARGET_DAILY_REVENUE_BRL=1000
WEEKLY_EBOOK_TARGET=3
MAX_AD_BUDGET_BRL=200

# --- Alertas ---
ALERT_EMAIL_TO=adersonvitoria@gmail.com
