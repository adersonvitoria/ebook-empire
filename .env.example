# ===== Ebook Empire — variaveis de ambiente =====
# Copie para .env e preencha. Em modo stub (USE_STUBS=true) as chaves externas
# podem ficar vazias — os adapters usam implementacoes deterministicas BR-first.

# --- Banco de dados ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ebook_empire?schema=public

# --- Runtime da API ---
NODE_ENV=development
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001

# --- Seguranca / Auth ---
JWT_SECRET=troque-este-segredo-em-producao

# --- Agentes / Scheduler ---
ENABLE_AGENTS=true
FAST_TICK_MS=60000
SLOW_TICK_MS=900000
MAX_AD_BUDGET_BRL=300
TARGET_DAILY_REVENUE_BRL=1000

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Mercado (setor MARKET_RESEARCH — Serper.dev) ---
# MARKET_DATA_PROVIDER=serper + SERPER_API_KEY para pesquisa real; USE_STUBS=true
# (default) forca o StubMarketDataAdapter deterministico mesmo com a chave setada.
MARKET_DATA_PROVIDER=stub
SERPER_API_KEY=
MARKET_SEARCH_GL=br
MARKET_SEARCH_HL=pt-br
MARKET_RESEARCH_WINDOW_DAYS=14
MARKET_MAX_QUERIES_PER_RUN=10

# --- QA / auditoria de ebooks (setor EBOOK_QA) ---
QA_MIN_SCORE=70
QA_MAX_FIX_ITERATIONS=2
QA_FAIL_SCORE=40
QA_AUDIT_STALE_HOURS=168

# --- Pagamento (Asaas / PIX) ---
PAYMENT_PROVIDER=asaas
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# --- Meta (Instagram Graph API + Ads Marketing API) ---
META_GRAPH_TOKEN=
META_AD_ACCOUNT_ID=

# --- Email (Resend / SMTP) ---
RESEND_API_KEY=

# --- Alertas externos (Feature 1) ---
# ALERTS_ENABLED = kill-switch global de alertas no boot (antes de AlertSettings no DB).
# Evolution vazio + WHATSAPP_PROVIDER=stub => StubWhatsApp (memoria, sem envio real).
ALERTS_ENABLED=true
ALERT_EMAIL_TO=
ALERT_WHATSAPP_TO=
ALERT_THROTTLE_MINUTES=60
WHATSAPP_PROVIDER=stub
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- Financeiro consolidado (Feature 2) — taxas Asaas PIX por transacao ---
# Placeholders plausiveis (0,99% + R$0,49). Confirmar com a operacao.
ASAAS_FEE_PERCENT=0.99
ASAAS_FEE_FIXED_CENTS=49

# --- Modo stub global (true = usa adapters stub, sem chamadas externas) ---
USE_STUBS=true

# --- Storage local (entrega via URL assinada) ---
STORAGE_DIR=./storage
